# SMTP Server Configuration
SMTP_TLS_ADDR=0.0.0.0:8465
SMTP_PLAIN_ADDR=0.0.0.0:8025

# SSL/TLS Certificate Paths
CERT_PATH=localhost.crt
KEY_PATH=localhost.key
FULLCHAIN_PATH=fullchain.pem
PRIVKEY_PATH=privkey.pem

# SMTP Authentication
SMTP_USERNAME=admin
SMTP_PASSWORD=password123

# MongoDB Configuration
# Pour MongoDB local (Docker Compose) : utiliser "mongodb" comme CLUSTER_URL
# Pour MongoDB Atlas : utiliser "your_cluster.mongodb.net"
MONGODB_USERNAME=admin
MONGODB_PASSWORD=password123
MONGODB_CLUSTER_URL=mongodb
MONGODB_APP_NAME=mailserver
MONGODB_DATABASE=mailserver

# Activer/désactiver le stockage MongoDB (true = MongoDB, false = fichiers locaux)
USE_MONGODB=true

# IMAP Server Configuration
IMAP_SERVER=0.0.0.0:143
IMAP_SERVER_API_PORT=8080

# API Server Configuration
API_SERVER_ADDR=0.0.0.0:8000

# Logging
RUST_LOG=debug

# URL du service DKIM (requis par email_api)
# DKIM_SERVICE_URL=http://your-dkim-service:3000/sign 